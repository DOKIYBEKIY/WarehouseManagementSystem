<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wms.mapper.SysRoleMapper">

    <select id="findAll" resultType="com.wms.entity.SysRole">
        select * from sys_role order by role_id
    </select>

    <select id="findById" resultType="com.wms.entity.SysRole">
        select * from sys_role where role_id=#{id}
    </select>

</mapper>
